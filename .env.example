# ── LangSmith (Observability & Tracing) ──────────────────────────────────────
# Register free account at: https://smith.langchain.com
LANGSMITH_API_KEY=API_KEY
LANGSMITH_PROJECT=text2sql-agent
# LANGSMITH_TRACING is set automatically in main.py when API_KEY is present

# ── Local LLM (Ollama) ───────────────────────────────────────────────────────
OLLAMA_MODEL=gemma4:4b
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=data/supermarket.db

# ── Debug ────────────────────────────────────────────────────────────────────
# Set to "true" to show SQL queries and stack traces
DEBUG=false
